# ═══════════════════════════════════════════════
# SHADOW SIGNALS — Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to GitHub
# ═══════════════════════════════════════════════

# ── Odds API (the-odds-api.com — 500 free calls/month) ──
ODDS_API_KEY=your_odds_api_key_here

# ── Database (Supabase free tier) ──────────────
DATABASE_URL=postgresql://postgres:your_password@db.your-project-ref.supabase.co:5432/postgres
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_KEY=your_service_role_key_here

# ── Stripe ─────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_your_secret_key_here_secret_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here
STRIPE_PRICE_RECRUIT_MONTH=price_your_recruit_monthly_price_id
STRIPE_PRICE_COMMANDER_MONTH=price_your_commander_monthly_price_id
STRIPE_PRICE_SYNDICATE_MONTH=price_your_syndicate_monthly_price_id

# ── Auth ───────────────────────────────────────
JWT_SECRET=generate_a_long_random_string_minimum_32_chars
JWT_EXPIRES_IN=7d

# ── Email (resend.com — 3k free/month) ─────────
RESEND_API_KEY=re_your_resend_api_key_here
EMAIL_FROM=noreply@yourdomain.com

# ── App ────────────────────────────────────────
PORT=3000
NODE_ENV=development
FRONTEND_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:3000/api
NEXT_PUBLIC_WS_URL=http://localhost:3000// Add this to your webhook endpoint
app.post('/api/webhook', express.raw({type: 'application/json'}), (req, res) => {
  const sig = req.headers['stripe-signature'];
  let event;

  try {
    event = stripe.webhooks.constructEvent(req.body, sig, process.env.STRIPE_WEBHOOK_SECRET);
  } catch (err) {
    return res.status(400).send(`Webhook Error: ${err.message}`);
  }

  switch (event.type) {
    case 'invoice.payment_failed':
      const failedInvoice = event.data.object;
      console.log(`Payment failed for customer ${failedInvoice.customer}`);
      console.log(`Attempt ${failedInvoice.attempt_count} of retries`);
      
      // Update user status in your database
      // Send notification to customer
      break;

    case 'invoice.payment_succeeded':
      const succeededInvoice = event.data.object;
      console.log(`Payment succeeded after retry for ${succeededInvoice.customer}`);
      
      // Restore user access
      // Send success notification
      break;

    case 'customer.subscription.updated':
      const subscription = event.data.object;
      if (subscription.status === 'past_due') {
        // Handle past due subscription
        console.log(`Subscription ${subscription.id} is past due`);
      }
      break;
  }

  res.status(200).json({received: true});
});
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your_anon_key_here

# ── Cache TTLs (seconds) ───────────────────────
CACHE_ODDS_TTL=45
CACHE_EV_TTL=60
CACHE_ARB_TTL=30