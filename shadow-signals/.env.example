# ═══════════════════════════════════════════════
# SHADOW SIGNALS — Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to GitHub
# ═══════════════════════════════════════════════

# ── Odds API (the-odds-api.com — 500 free calls/month) ──
ODDS_API_KEY="your_odds_api_key_here"

# ── Database (Supabase free tier) ──────────────
# Get from: supabase.com → project → settings → database → URI
DATABASE_URL="postgresql://postgres:your_password@db.your-project-ref.supabase.co:5432/postgres"

# ── Stripe ─────────────────────────────────────
# Use TEST keys for dev, LIVE keys for production
STRIPE_PUBLISHABLE_KEY="pk_test_your_publishable_key_here"
STRIPE_SECRET_KEY="sk_test_your_secret_key_here"
STRIPE_WEBHOOK_SECRET="whsec_your_webhook_secret_here"

# Filled automatically by: node scripts/stripeSetup.js
STRIPE_PRICE_RECRUIT_MONTH="price_your_recruit_monthly_price_id"
STRIPE_PRICE_COMMANDER_MONTH="price_your_commander_monthly_price_id"
STRIPE_PRICE_SYNDICATE_MONTH="price_your_syndicate_monthly_price_id"

# ── Auth ───────────────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET="generate_a_long_random_string_here_minimum_32_chars"
JWT_EXPIRES_IN=7d

# ── Email (resend.com — 3k free/month) ─────────
RESEND_API_KEY="re_your_resend_api_key_here"
EMAIL_FROM="noreply@shadowsignals.com.au"

# ── App ────────────────────────────────────────
PORT=3001
FRONTEND_URL=http://localhost:3000
NODE_ENV=development

# Client-side env vars used by the Next.js app
NEXT_PUBLIC_API_URL=http://localhost:3001/api
NEXT_PUBLIC_WS_URL=http://localhost:3001

# ── Cache TTLs (seconds) ───────────────────────
CACHE_ODDS_TTL=45
CACHE_EV_TTL=60
CACHE_ARB_TTL=30
