# ═══════════════════════════════════════════════
# SHADOW SIGNALS — Environment Variables (EXAMPLE)
# ═══════════════════════════════════════════════
# Copy this file to .env and fill in your values
# cp .env.example .env

# ── Odds API (BoltOdds / spro.agency) ──────────
ODDS_API_KEY=your_odds_api_key_here
ODDS_API_PROVIDER=boltodds
BOLTODDS_KEY=your_boltodds_key_here
BOLTODDS_WS_URL=wss://spro.agency/api
BOLTODDS_REST_URL=https://spro.agency/api
SPORT_GAME_ODDS=your_sport_game_odds_key_here

# ── Database (Supabase) ─────────────────────────
DATABASE_URL=postgresql://user:password@host:6543/postgres?pgbouncer=true
DIRECT_URL=postgresql://user:password@host:5432/postgres
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_KEY=your_supabase_service_key

# ── Stripe ──────────────────────────────────────
STRIPE_PUBLISHABLE_KEY=[REPLACE_ME_with_your_Stripe_publishable_key]
STRIPE_SECRET_KEY=[REPLACE_ME_with_your_Stripe_secret_key]
STRIPE_WEBHOOK_SECRET=[REPLACE_ME_with_your_Stripe_webhook_secret]
STRIPE_PRICE_FREE_MONTH=price_xxx
STRIPE_PRICE_STARTER_MONTH=price_xxx
STRIPE_PRICE_PRO_MONTH=price_xxx
STRIPE_PRICE_ELITE_MONTH=price_xxx

# ── Auth ────────────────────────────────────────
JWT_SECRET=generate_a_random_64_char_hex_secret
JWT_EXPIRES_IN=7d

# ── Email (resend.com) ──────────────────────────
RESEND_API_KEY=re_your_resend_key
EMAIL_FROM=noreply@yourdomain.com

# ── App ─────────────────────────────────────────
PORT=3001
NODE_ENV=development
FRONTEND_URL=http://localhost:3000

# Client-side env vars for Next.js (NEXT_PUBLIC_* are bundled to browser!)
NEXT_PUBLIC_API_URL=http://localhost:3001/api
NEXT_PUBLIC_WS_URL=http://localhost:3001
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# ── Cache TTLs (seconds) ────────────────────────
CACHE_ODDS_TTL=45
CACHE_EV_TTL=60
CACHE_ARB_TTL=30