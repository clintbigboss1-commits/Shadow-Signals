{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "buildCommand": "cd shadow-signals && npm install"
  },
  "deploy": {
    "numReplicas": 1,
    "startCommand": "cd shadow-signals && node server/index.js",
    "healthcheckPath": "/api/health",
    "healthcheckTimeout": 30,
    "restartPolicyType": "always"
  }
}
